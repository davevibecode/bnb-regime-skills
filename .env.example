# ─── CoinMarketCap Pro API ─────────────────────────────────────────────────────
# Get your key from https://pro.coinmarketcap.com/login
CMC_API_KEY=your-cmc-pro-api-key-here
CMC_BASE_URL=https://pro-api.coinmarketcap.com

# CMC MCP Server (alternative access path — same key)
# CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# ─── Regime Detection Config ──────────────────────────────────────────────────
# Comma-separated CMC symbols this Skill evaluates. Default: majors.
REGIME_SYMBOLS=BTC,ETH,BNB

# Lookback window in days for regime classification
REGIME_LOOKBACK_DAYS=14

# Re-evaluation interval in hours (how often the regime can flip)
REGIME_REFRESH_HOURS=4

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
